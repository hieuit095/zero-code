# ─── Multi-Agent IDE — Staging Environment ────────────────────────────────────
# Copy this file to .env.staging and fill in the values for your staging deployment.

# FastAPI Backend
PYTHONUNBUFFERED=1
LOG_LEVEL=info

# Database (SQLite for staging — swap to Postgres connection string for production)
DATABASE_URL=sqlite+aiosqlite:///./data/sql_app.db
# DATABASE_URL=postgresql+asyncpg://zerocode:changeme@postgres:5432/zerocode

# ─── Backend Required Config (mapped to backend/.env) ────────────────────────
# Fernet key for encrypting LLM API keys at rest (32 bytes, base64 url-safe)
FERNET_KEY=zAxrKLrkomm25IrkP66XhNLo0A9gfvWIGTqOza-nYEo=

# Shared JWT secret for MCP agent authentication
MCP_JWT_SECRET=ziYoP-f-br4i8iZ_TYfs5dYv2Ftqv0GyIUyFaHH--CE

# Shared API key secret for internal service-to-service auth
API_KEY_SECRET=SuUVg3zGD3wehXvweLxzb7bZoWklmiFPA2-KKAjdFpk

# Redis (for future event broker upgrade)
REDIS_URL=redis://redis:6379/0

# OpenHands Sandbox (internal service name — never exposed to host)
# OPENHANDS_RUNTIME_URL=http://openhands-runtime:3000

# Frontend build-time variable
VITE_API_BASE_URL=http://localhost:8000

