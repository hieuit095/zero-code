# ╔══════════════════════════════════════════════════════════════════════╗
# ║                    Zero-Code IDE — Environment                      ║
# ║  Copy to `.env` and fill in values for both API + Worker processes  ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ─── REQUIRED ─────────────────────────────────────────────────────────
# JWT secret shared between the FastAPI API server and the background
# Worker. MUST be identical across both processes. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
MCP_JWT_SECRET=

# ─── Redis ────────────────────────────────────────────────────────────
# Event bus (Pub/Sub) and task queue for Worker dispatch.
REDIS_URL=redis://localhost:6379/0

# ─── LLM Provider ────────────────────────────────────────────────────
# API key for the LLM used by Nanobot agents (Leader/Dev/QA).
LLM_API_KEY=
LLM_MODEL=anthropic/claude-sonnet-4-5-20250929
LLM_BASE_URL=

# ─── OpenHands SDK ────────────────────────────────────────────────────
# Legacy REST fallback (optional — SDK mode preferred).
OPENHANDS_API_URL=http://localhost:3000
OPENHANDS_API_KEY=

# ─── Server ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Workspace ────────────────────────────────────────────────────────
WORKSPACE_DIR=./workspaces

# ─── CORS ─────────────────────────────────────────────────────────────
# Comma-separated origins allowed by the API server.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# ─── Frontend (Vite) ─────────────────────────────────────────────────
# Used by the React client to connect to the API/WS backend.
VITE_API_BASE_URL=http://127.0.0.1:8000
