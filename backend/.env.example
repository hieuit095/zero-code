# Required durable runtime dependencies
DATABASE_URL=postgresql+asyncpg://zerocode:zerocode@localhost:5432/zerocode
REDIS_URL=redis://localhost:6379/0
API_KEY_SECRET=replace-with-a-long-random-secret
MCP_JWT_SECRET=replace-with-a-different-long-random-secret

# OpenHands sandbox configuration
OPENHANDS_API_URL=http://localhost:3000
OPENHANDS_API_KEY=

# LLM configuration for the OpenHands SDK runtime
LLM_API_KEY=
LLM_MODEL=anthropic/claude-sonnet-4-5-20250929
LLM_BASE_URL=

# Workspace
WORKSPACE_DIR=./workspaces

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Server
HOST=0.0.0.0
PORT=8000
